<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local NuGet config for reproducible restores. We <clear/> any inherited machine/global
    sources (e.g. private feeds) so every developer and CI restores the same public packages, and
    we map all packages to nuget.org as required by Central Package Management (avoids NU1507).
    All dependencies in Directory.Packages.props are public nuget.org packages.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
